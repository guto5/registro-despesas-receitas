DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/despesas_receitas?schema=public"

# Key para assinar JWT
JWT_SECRET="your-secret-here"

# SMTP — deixe em branco para usar Ethereal (pré-visualização no console)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
EMAIL_FROM="financas@example.com"
EMAIL_TO="admin@example.com"

# Credenciais Ethereal geradas (usado quando SMTP_HOST estiver vazio)
ETHEREAL_USER=""
ETHEREAL_PASS=""
