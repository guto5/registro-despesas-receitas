generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id       String @id @default(uuid()) @db.Uuid
  nome     String
  login    String @unique
  senha    String
  situacao String

  @@map("usuario")
}

model Lancamento {
  id              String   @id @default(uuid()) @db.Uuid
  descricao       String
  data_lancamento DateTime
  valor           Decimal  @db.Decimal(12, 2)
  tipo_lancamento String
  situacao        String

  @@map("lancamento")
}
